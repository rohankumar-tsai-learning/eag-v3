# Required: Gemini free-tier key and model
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite

# Global cooldown across all architecture roles (max 1 LLM call per minute)
LLM_COOLDOWN_SECONDS=60

# Agent runtime controls
MAX_ITERATIONS=14
ARTIFACT_THRESHOLD_BYTES=4096
ATTACH_MAX_CHARS=20000

# Filesystem state
STATE_DIR=state
MEMORY_FILE=memory.json
ARTIFACT_DIR=artifacts

# MCP server process (stdio transport)
MCP_SERVER_COMMAND=uv
MCP_SERVER_ARGS=run,mcp_server.py

# LLM behavior
PERCEPTION_TEMPERATURE=1.0
DECISION_TEMPERATURE=0.3
MEMORY_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=90
TOOL_TIMEOUT_SECONDS=60

# MCP server optional settings
# If set and valid, web_search will use Tavily first, then DDG fallback.
TAVILY_API_KEY=your_tavily_api_key_here
# Keep false unless you explicitly want crawl4ai mode for fetch_url.
FETCH_USE_CRAWL4AI=false

# Optional: set true for local deterministic testing without API calls
MOCK_LLM=false
