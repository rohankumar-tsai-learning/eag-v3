# CelesTrak endpoint template for TLE fetches.
# Keep {id} placeholder unchanged.
CELESTRAK_URL_TEMPLATE=https://celestrak.org/NORAD/elements/gp.php?CATNR={id}&FORMAT=TLE

# HTTP timeout (seconds) for TLE requests.
TLE_REQUEST_TIMEOUT_SECONDS=15

# Skyfield ephemeris filename/path.
SKYFIELD_EPHEMERIS_FILE=de421.bsp
EPHEMERIS_AUTO_DOWNLOAD=true
EPHEMERIS_DOWNLOAD_URL=https://ssd.jpl.nasa.gov/ftp/eph/planets/bsp/de421.bsp

# MCP server metadata.
MCP_SERVER_NAME=Orbital Predictor & Visibility
MCP_TRANSPORT=streamable-http
MCP_HOST=127.0.0.1
MCP_PORT=8001
MCP_PATH=/mcp

# Logging configuration.
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s | %(levelname)s | %(name)s | %(message)s
LOG_FILE_PATH=logs/orbital_predictor_mcp.log
