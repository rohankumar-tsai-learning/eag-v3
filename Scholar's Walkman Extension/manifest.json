{
  "manifest_version": 3,
  "name": "Scholar's Walkman",
  "version": "1.0",
  "description": "Professional Text-to-Speech tool featuring synchronized word highlighting on technical sites.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon48.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.arxiv.org/*",
    "*://arxiv.org/*",
    "*://scholar.google.com/*",
    "*://*.huggingface.co/*",
    "*://huggingface.co/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.arxiv.org/*",
        "*://arxiv.org/*",
        "*://scholar.google.com/*",
        "*://*.huggingface.co/*",
        "*://huggingface.co/*"
      ],
      "css": ["content.css"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [{
    "resources": ["content.css", "config.js"],
    "matches": ["<all_urls>"]
  }]
}
